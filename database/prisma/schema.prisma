generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
}

enum RoleName {
  EMPLOYEE
  PROCESS_OWNER
  COMPLIANCE_MANAGER
  AUDITOR
  ADMIN
}

enum DeviationStatus {
  REPORTED
  UNDER_REVIEW
  CAPA_ASSIGNED
  RESOLVED
  CLOSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CAPAStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum CommentEntityType {
  DEVIATION
  CAPA
  AUDIT
}

enum NotificationType {
  CAPA_ASSIGNED
  DEVIATION_STATUS_CHANGED
  AUDIT_SCHEDULED
}

enum ActivityEntityType {
  SOP
  DEVIATION
  CAPA
  AUDIT
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?

  users User[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  department   String?
  isActive     Boolean  @default(true)
  roleId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id])

  ownedSOPs       SOP[]        @relation("SOPOwner")
  createdSOPVersions SOPVersion[] @relation("SOPVersionCreator")
  reportedDeviations Deviation[] @relation("ReportedBy")
  ownedDeviations    Deviation[] @relation("DeviationOwner")
  assignedCAPAs      CAPA[]     @relation("CAPAAssignee")
  createdCAPAs       CAPA[]     @relation("CAPACreator")
  auditsAsAuditor    Audit[]    @relation("AuditAuditor")
  comments           Comment[]
  notifications      Notification[]
  activityLogs       ActivityLog[] @relation("ActivityActor")
}

model SOP {
  id         String      @id @default(cuid())
  title      String
  code       String
  department String?
  ownerId    String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  owner    User        @relation("SOPOwner", fields: [ownerId], references: [id])
  versions SOPVersion[]
  deviations Deviation[]

  @@unique([code])
}

model SOPVersion {
  id           String   @id @default(cuid())
  sopId        String
  versionNumber Int
  content      String
  changeSummary String?
  createdById  String
  isCurrent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  sop       SOP  @relation(fields: [sopId], references: [id])
  createdBy User @relation("SOPVersionCreator", fields: [createdById], references: [id])

  @@unique([sopId, versionNumber])
}

model Deviation {
  id           String          @id @default(cuid())
  title        String
  description  String
  severity     Severity
  status       DeviationStatus @default(REPORTED)
  department   String?
  relatedSopId String?
  reportedById String
  ownerId      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  relatedSop SOP? @relation(fields: [relatedSopId], references: [id])
  reportedBy User @relation("ReportedBy", fields: [reportedById], references: [id])
  owner      User? @relation("DeviationOwner", fields: [ownerId], references: [id])
  capa       CAPA? @relation("DeviationCAPA")

  @@index([status, department])
  @@index([createdAt])
}

model CAPA {
  id                 String     @id @default(cuid())
  title              String
  description        String
  assignedToId       String
  createdById        String
  status             CAPAStatus @default(OPEN)
  deadline           DateTime?
  progress           Int        @default(0)
  relatedDeviationId String?    @unique
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  assignedTo       User       @relation("CAPAAssignee", fields: [assignedToId], references: [id])
  createdBy        User       @relation("CAPACreator", fields: [createdById], references: [id])
  relatedDeviation Deviation? @relation("DeviationCAPA", fields: [relatedDeviationId], references: [id])

  @@index([status, deadline])
}

model Audit {
  id            String       @id @default(cuid())
  name          String
  department    String?
  auditorId     String
  scheduledDate DateTime
  status        AuditStatus  @default(PLANNED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  auditor  User           @relation("AuditAuditor", fields: [auditorId], references: [id])
  findings AuditFinding[]

  @@index([scheduledDate, status])
}

model AuditFinding {
  id                String    @id @default(cuid())
  auditId           String
  title             String
  description       String
  severity          Severity

  audit           Audit     @relation(fields: [auditId], references: [id])
}

model Comment {
  id         String            @id @default(cuid())
  entityType CommentEntityType
  entityId   String
  authorId   String
  body       String
  parentId   String?
  createdAt  DateTime          @default(now())

  author User @relation(fields: [authorId], references: [id])
  parent Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String
  entityType ActivityEntityType?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}

model ActivityLog {
  id         String             @id @default(cuid())
  entityType ActivityEntityType
  entityId   String
  action     String
  actorId    String?
  metadata   Json?
  createdAt  DateTime           @default(now())

  actor User? @relation("ActivityActor", fields: [actorId], references: [id])
}

